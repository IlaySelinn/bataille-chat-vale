<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>
<?import school.coda.ilay_luisa.bataillejavale.view.BoardView?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="school.coda.ilay_luisa.bataillejavale.controllers.BattleController"
            prefWidth="2000" prefHeight="1000">

    <top>
        <VBox alignment="CENTER" spacing="10">
            <padding>
                <Insets top="20" bottom="20"/>
            </padding>
            <Label text="Bataille Navale des Chats" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
            <Label fx:id="turnLabel" text="Tour n°1" style="-fx-font-size: 16px;"/>
        </VBox>
    </top>

    <center>
        <HBox spacing="50" alignment="CENTER">

            <VBox alignment="CENTER" spacing="10">
                <Label text="Radar (Tirez ici !)" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: red;"/>
                <BoardView fx:id="radarGrid" />
            </VBox>

            <VBox alignment="CENTER" spacing="10">
                <Label text="Vos Chats" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: blue;"/>
                <BoardView fx:id="playerGrid"/>
            </VBox>

        </HBox>
    </center>

    <bottom>
        <VBox spacing="10" alignment="CENTER">
            <padding>
                <Insets top="20" bottom="20" left="50" right="50"/>
            </padding>
            <Label text="Historique des coups" style="-fx-font-weight: bold;"/>
            <TextArea fx:id="historyLabel" prefHeight="150" editable="false" wrapText="true"/>
        </VBox>
    </bottom>

</BorderPane>