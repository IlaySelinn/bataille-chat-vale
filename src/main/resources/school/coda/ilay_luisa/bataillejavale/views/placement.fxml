<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import school.coda.ilay_luisa.bataillejavale.view.BoardViev?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="school.coda.ilay_luisa.bataillejavale.controllers.PlacementController">

    <!-- Titre -->
    <top>
        <Label text="Placement des chats"
               style="-fx-font-size: 20px;"
               BorderPane.alignment="CENTER"/>
    </top>

    <!-- Canvas du plateau -->
    <center>
        <BoardViev fx:id="boardView" onMouseClicked="#handleBoardViewClick"/>
    </center>

    <!-- Contrôles -->
    <bottom>
        <VBox spacing="10" alignment="CENTER">


            <!-- Menus déroulants -->
            <HBox spacing="10" alignment="CENTER">
                <!-- Ligne 1 à 10 -->
                <Label text="Ligne:"/>
                <ComboBox fx:id="lineCombo" prefWidth="60"/>

                <!-- Colonne A à J -->
                <Label text="Colonne:"/>
                <ComboBox fx:id="colCombo" prefWidth="60"/>

                <!-- Orientation H/V -->
                <Label text="Orientation:"/>
                <ComboBox fx:id="orientationCombo" prefWidth="80"/>

                <!-- Type de chat -->
                <Label text="Chat:"/>
                <ComboBox fx:id="catTypeCombo" prefWidth="120"/>

                <!-- Bouton placer -->
                <Button fx:id="placeButton" text="Placer" onAction="#placeCatFromMenu"/>
            </HBox>

            <!-- Bouton commencer bataille -->
            <Button fx:id="startButton" text="Commencer la bataille" onAction="#startBattle"/>
        </VBox>
    </bottom>

</BorderPane>